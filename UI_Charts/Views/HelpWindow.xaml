<Window x:Class="UICharts.Desktop.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Справка"
        Width="520"
        Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border Margin="10"
            Padding="15"
            BorderBrush="Black"
            BorderThickness="2"
            CornerRadius="10"
            Background="White">

        <StackPanel>
            <TextBlock Text="UICharts V1.0"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Редактор блок-схем"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Возможности:"
                       FontWeight="Bold"/>

            <TextBlock Text="• создание блок-схем"/>
            <TextBlock Text="• перемещение и изменение размеров фигур"/>
            <TextBlock Text="• соединение блоков стрелками"/>
            <TextBlock Text="• сохранение и загрузка JSON"/>
            <TextBlock Text="• экспорт схемы в PNG"/>

            <Separator Margin="0,15"/>

            <TextBlock Text="Управление:"
                       FontWeight="Bold"/>

            <TextBlock Text="• Двойной щелчок — редактирование текста"/>
            <TextBlock Text="• Shift + клик — создание связи"/>
            <TextBlock Text="• Delete — удаление выбранного блока"/>
            <TextBlock Text="• Синий маркер — изменение размера"/>

            <Separator Margin="0,15"/>

            <TextBlock Text="Технологии:"
                       FontWeight="Bold"/>

            <TextBlock Text="WPF, MVVM, Prism, JSON"/>
            
            <Separator Margin="0,15"/>
            
            <TextBlock Text="Авторы:"
                       FontStyle="Italic"
                       HorizontalAlignment="Right"/>
            <TextBlock Text="Соловьев Э.А., Викульев В.А."
                       FontStyle="Italic"
                       HorizontalAlignment="Right"/>    
        </StackPanel>
    </Border>
</Window>