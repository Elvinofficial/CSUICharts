<Window 
    
    x:Class="UI_Charts.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:UICharts.Desktop.ViewModels"
    xmlns:views="clr-namespace:UICharts.Desktop.Views"
    xmlns:prism="http://prismlibrary.com/"
    mc:Ignorable="d"
    Title="Редактор блок-схем"
    Height="720"
    Width="1250">
    
    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Grid 
        Background="#F3F3F3"
        Margin="20">
        <Border 
            CornerRadius="35"        
            BorderThickness="2"
            Background="#F3F3F3"
            Padding="18"
            Margin="-16,-19,-18,-17">
            <Grid>
                    
                <Grid.RowDefinitions>
                    <RowDefinition Height="66"/>
                    <RowDefinition/>
                    <RowDefinition Height="70"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ToolboxView -->
                <views:ToolboxView 
                    Grid.Row="0"
                    Grid.RowSpan="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"/>

                <!-- WorkSpaceView (должно быть, пока все тут) -->
                <Border 
                    Grid.Row="0"
                    Grid.Column="2"
                    CornerRadius="8"
                    BorderBrush="Black"
                    BorderThickness="2"
                    Background="#ECECEC"
                    Margin="0,-15,0,10"
                    Padding="8">    

                    <TabControl 
                        ItemsSource="{Binding Workspaces}"
                        SelectedItem="{Binding SelectedWorkspace}"
                        Background="#ECECEC"
                        BorderThickness="2">

                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Margin="10,2" FontSize="14"/>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        
                        <!-- Заглушка, почему то появляется имя объекта -->
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <Grid/>
                            </DataTemplate>
                        </TabControl.ContentTemplate>

                    </TabControl>

                </Border>

                <!-- EditorView -->
                <views:EditorView
                    DataContext="{Binding Editor}"
                    Grid.Row="1"
                    Grid.Column="2"
                    Grid.RowSpan="2"/>




                <!-- Нижняя панель (тоже должно быть отдельным View) -->
                <Border
                    Grid.Row="2"
                    Grid.Column="2"
                    CornerRadius="8"
                    BorderBrush="Black"
                    BorderThickness="2"
                    Background="#ECECEC"
                    Padding="10"
                    Margin="0,30,0,-15">

                    <StackPanel
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                            
                        <Button
                            Content="Создать"
                            Width="120"
                            Height="35"
                            Margin="10,0"
                            Command="{Binding CreateWorkspaceCommand}"/>

                        <Button
                            Content="Открыть"
                            Width="120"
                            Height="35"
                            Margin="10,0"/>

                        <Button
                            Content="Сохранить"
                            Width="120"
                            Height="35"
                            Margin="10,0"/>

                        <Button
                            Content="Экспортировать"
                            Width="120"
                            Height="35"
                            BorderThickness="2"
                            Margin="10,0"/>
                        
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>