<UserControl x:Class="UICharts.Desktop.Views.EditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:UICharts.Desktop.ViewModels"
             xmlns:enums="clr-namespace:UICharts.Core.Enums;assembly=UICharts.Core"
             mc:Ignorable="d"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DataContext="{d:DesignInstance vm:EditorViewModel, IsDesignTimeCreatable=False}"
             xmlns:behaviors="clr-namespace:UICharts.Desktop.Behaviors"
             d:DesignHeight="450"
             d:DesignWidth="800">
             <!--d:DataContext="{d:DesignInstance Type=viewmodels:EditorViewModel}"-->
    
    
    <UserControl.Resources>
    <ResourceDictionary>

        <DrawingBrush x:Key="EditorGridBrush"
                      TileMode="Tile"
                      Viewport="0,0,20,20"
                      ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <GeometryDrawing Brush="#ECECEC">
                    <GeometryDrawing.Pen>
                        <Pen Brush="#D0D0D0" Thickness="0.5"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,0" EndPoint="20,0"/>
                            <LineGeometry StartPoint="0,0" EndPoint="0,20"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="pack://application:,,,/UICharts.Desktop;component/Resources/BlockTemplates.xaml"/>
        </ResourceDictionary.MergedDictionaries>

    </ResourceDictionary>
</UserControl.Resources>
    
    <Border CornerRadius="35"
            BorderBrush="Black"
            BorderThickness="2"
            Background="#ECECEC"
            Padding="10">

        <Grid x:Name="EditorViewport"
      ClipToBounds="True"
      Background="{StaticResource EditorGridBrush}"
      behaviors:EditorCanvasBehavior.MouseWheelCommand="{Binding MouseWheelCommand}"
      behaviors:EditorCanvasBehavior.PanMouseDownCommand="{Binding PanMouseDownCommand}"
      behaviors:EditorCanvasBehavior.PanMouseMoveCommand="{Binding PanMouseMoveCommand}"
      behaviors:EditorCanvasBehavior.PanMouseUpCommand="{Binding PanMouseUpCommand}">

            <Canvas x:Name="EditorCanvas"
        Width="{Binding CanvasWidth}"
        Height="{Binding CanvasHeight}"
            Background="Transparent"
            behaviors:EditorCanvasBehavior.CanvasClickCommand="{Binding CanvasClickCommand}"
            behaviors:EditorCanvasBehavior.MouseMoveCommand="{Binding CanvasMouseMoveCommand}">

                <Canvas.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="{Binding Zoom}"
                                ScaleY="{Binding Zoom}" />
                        <TranslateTransform X="{Binding PanX}"
                                    Y="{Binding PanY}" />
                    </TransformGroup>
                </Canvas.RenderTransform>
                <!-- Линии снизу -->
                <ItemsControl ItemsSource="{Binding Connections}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <!-- Толстая невидимая зона клика -->
                                <Polyline Points="{Binding RoutePoints}"
          Stroke="#01000000"
          StrokeThickness="18"
          Cursor="Hand"
                                          ToolTip="{Binding Text}"
          behaviors:ConnectionClickBehavior.InteractionCanvas="{Binding ElementName=EditorCanvas}"
          behaviors:ConnectionClickBehavior.DoubleClickCommand="{Binding DataContext.AddConnectionBendPointCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                    <Polyline.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding DataContext.SelectConnectionCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      CommandParameter="{Binding}" />
                                    </Polyline.InputBindings>
                                </Polyline>

                                <!-- Видимая линия -->
                                <Polyline Points="{Binding RoutePoints}"
                          StrokeThickness="2"
                                          behaviors:ConnectionClickBehavior.InteractionCanvas="{Binding ElementName=EditorCanvas}"
                                          behaviors:ConnectionClickBehavior.DoubleClickCommand="{Binding DataContext.AddConnectionBendPointCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                    <Polyline.Style>
                                        <Style TargetType="Polyline">
                                            <Setter Property="Stroke" Value="Black"/>
                                            <Setter Property="StrokeThickness" Value="2"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Stroke" Value="DodgerBlue"/>
                                                    <Setter Property="StrokeThickness" Value="3"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Polyline.Style>
                                </Polyline>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding Connections}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <ItemsControl ItemsSource="{Binding BendPoints}"
              Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">

                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">

                                        <Setter Property="Canvas.Left"
                                Value="{Binding X}" />

                                        <Setter Property="Canvas.Top"
                                Value="{Binding Y}" />

                                    </Style>
                                </ItemsControl.ItemContainerStyle>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>

                                        <Ellipse Width="12"
         Height="12"
         Fill="Orange"
         Stroke="Black"
         StrokeThickness="1"
         Margin="-6,-6,0,0"
         Cursor="SizeAll"
         Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
         behaviors:BendPointDragBehavior.InteractionCanvas="{Binding ElementName=EditorCanvas}"
         behaviors:BendPointDragBehavior.MouseDownCommand="{Binding DataContext.BendPointMouseDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
         behaviors:BendPointDragBehavior.MouseMoveCommand="{Binding DataContext.BendPointMouseMoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
         behaviors:BendPointDragBehavior.MouseUpCommand="{Binding DataContext.BendPointMouseUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                            <Ellipse.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Удалить точку"
                  Command="{Binding PlacementTarget.Tag.DeleteBendPointCommand,
                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                  CommandParameter="{Binding}"/>
                                                </ContextMenu>
                                            </Ellipse.ContextMenu>
                                        </Ellipse>

                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>

                            </ItemsControl>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Фантомная линия должна быть отдельно -->
                <Polyline Points="{Binding PreviewRoutePoints}"
          Stroke="Gray"
          StrokeThickness="2"
          StrokeDashArray="5 3"
          Visibility="{Binding IsConnectionPreviewVisible,
                       Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <!-- Маркеры начала выбранной связи -->
                <ItemsControl ItemsSource="{Binding Connections}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding StartHandle.X}" />
                            <Setter Property="Canvas.Top" Value="{Binding StartHandle.Y}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Ellipse Width="12"
                     Height="12"
                     Fill="MediumPurple"
                     Stroke="White"
                     StrokeThickness="2"
                     Cursor="Hand"
                     Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                     behaviors:ConnectionEndpointDragBehavior.InteractionCanvas="{Binding ElementName=EditorCanvas}"
                     behaviors:ConnectionEndpointDragBehavior.MouseDownCommand="{Binding DataContext.ConnectionStartMouseDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     behaviors:ConnectionEndpointDragBehavior.MouseMoveCommand="{Binding DataContext.ConnectionStartMouseMoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     behaviors:ConnectionEndpointDragBehavior.MouseUpCommand="{Binding DataContext.ConnectionStartMouseUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding Connections}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Ellipse Width="12"
Height="12"
Fill="DodgerBlue"
Stroke="White"
StrokeThickness="2"
Cursor="Hand"
Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
behaviors:ConnectionEndpointDragBehavior.InteractionCanvas="{Binding ElementName=EditorCanvas}"
behaviors:ConnectionEndpointDragBehavior.MouseDownCommand="{Binding DataContext.ConnectionEndMouseDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
behaviors:ConnectionEndpointDragBehavior.MouseMoveCommand="{Binding DataContext.ConnectionEndMouseMoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
behaviors:ConnectionEndpointDragBehavior.MouseUpCommand="{Binding DataContext.ConnectionEndMouseUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform X="{Binding EndHandle.X}"
                   Y="{Binding EndHandle.Y}" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <!-- Подписи связей -->
                <ItemsControl ItemsSource="{Binding Connections}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding LabelPosition.X}" />
                            <Setter Property="Canvas.Top" Value="{Binding LabelPosition.Y}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                    MinWidth="40"
MinHeight="22"
Padding="6,2"
                     FontSize="12"
                     TextAlignment="Center"
                     Background="#EEFFFFFF"
                     BorderBrush="Gray"
                     BorderThickness="1"
                                     AcceptsReturn="True"
TextWrapping="Wrap"
                                     VerticalContentAlignment="Center"
                     Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Блоки -->
                <ItemsControl ItemsSource="{Binding Blocks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding}">
                                <ContentControl.Style>
                                    <Style TargetType="ContentControl">
                                        <Setter Property="ContentTemplate"
                                            Value="{StaticResource ProcessTemplate}" />

                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}"
                                                     Value="{x:Static enums:BlockType.Decision}">
                                                <Setter Property="ContentTemplate"
                                                    Value="{StaticResource DecisionTemplate}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}"
             Value="{x:Static enums:BlockType.Loop}">
                                                <Setter Property="ContentTemplate"
            Value="{StaticResource LoopTemplate}" />
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding Type}"
             Value="{x:Static enums:BlockType.Procedure}">
                                                <Setter Property="ContentTemplate"
            Value="{StaticResource ProcedureTemplate}" />
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding Type}"
             Value="{x:Static enums:BlockType.Reference}">
                                                <Setter Property="ContentTemplate"
            Value="{StaticResource ReferenceTemplate}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}"
             Value="{x:Static enums:BlockType.Start}">
                                                <Setter Property="ContentTemplate"
            Value="{StaticResource StartEndTemplate}" />
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding Type}"
             Value="{x:Static enums:BlockType.End}">
                                                <Setter Property="ContentTemplate"
            Value="{StaticResource StartEndTemplate}" />
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding Type}"
                                                     Value="{x:Static enums:BlockType.StartEnd}">
                                                <Setter Property="ContentTemplate"
                                                    Value="{StaticResource StartEndTemplate}" />
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding Type}"
                                                     Value="{x:Static enums:BlockType.InputOutput}">
                                                <Setter Property="ContentTemplate"
                                                    Value="{StaticResource InputOutputTemplate}" />
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding Type}"
                                                     Value="{x:Static enums:BlockType.Process}">
                                                <Setter Property="ContentTemplate"
                                                    Value="{StaticResource ProcessTemplate}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ContentControl.Style>
                            </ContentControl>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Стрелки сверху -->
                <ItemsControl ItemsSource="{Binding Connections}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Polygon Points="{Binding ArrowPoints}"
                     Fill="Black"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </Canvas>
        </Grid>
    </Border>
</UserControl>