<Window x:Class="UI_Charts.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:UICharts.Desktop.ViewModels"
        xmlns:prism="http://prismlibrary.com/"
        mc:Ignorable="d"
        Title="Редактор блок-схем"
        Height="717"
        Width="1246">
    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Grid Background="#F3F3F3" Margin="20">

        <Border CornerRadius="35"
                
                BorderThickness="2"
                Background="#F3F3F3"
                Padding="18" Margin="-16,-19,-18,-17">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="66"/>
                    <RowDefinition/>
                    <RowDefinition Height="70"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Левая панель -->
                <Border Grid.Row="0"
        Grid.RowSpan="3"
        Grid.Column="0"
        CornerRadius="25"
        BorderBrush="Black"
        BorderThickness="2"
        Background="#ECECEC"
        Padding="10" Margin="-19,-15,5,-15" Grid.ColumnSpan="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="57*"/>
                            <RowDefinition Height="91*"/>
                            <RowDefinition Height="50"/>
                        </Grid.RowDefinitions>

                        <TextBlock
                   Text="Фигуры"
                   FontSize="20"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

                        <ListBox
                 ItemsSource="{Binding Figures}"
                 SelectedItem="{Binding SelectedFigure}"
                 DisplayMemberPath="Name"
                 Background="#ECECEC"
                 Margin="0,43,0,39"
                 FontSize="16" Grid.RowSpan="4"
                 BorderBrush="#ECECEC"
                 HorizontalContentAlignment="Center"
                 RenderTransformOrigin="0.508,0.536"/>

                        <TextBlock Grid.Row="3"
                   Text="{Binding SelectedFigure.Name, StringFormat=Выбрано: {0}}"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"/>
                    </Grid>
                </Border>

                <!-- Верхняя панель -->
                <Border Grid.Row="0"
        Grid.Column="2"
        CornerRadius="8"
        BorderBrush="Black"
        BorderThickness="2"
        Background="#ECECEC"
        Margin="0,-15,0,10"
        Padding="8">

                    <TabControl ItemsSource="{Binding Workspaces}"
                SelectedItem="{Binding SelectedWorkspace}"
                Background="#ECECEC"
                BorderThickness="2">

                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"
                           Margin="10,2"
                           FontSize="14"/>
                            </DataTemplate>
                        </TabControl.ItemTemplate>

                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <Grid/>
                            </DataTemplate>
                        </TabControl.ContentTemplate>

                    </TabControl>

                </Border>

                <!-- Центральная область -->

                <Border Grid.Row="1"
        Grid.Column="2"
        CornerRadius="35"
        BorderBrush="Black"
        BorderThickness="2"
        Background="#ECECEC"
        Margin="0,0,0,45"
        Padding="20" Grid.RowSpan="2">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                   Text="Рабочее поле редактора"
                   FontSize="28"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"/>

                        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Center">
                            <TextBlock Text="{Binding SelectedWorkspaceName, StringFormat=Активное окно: {0}}"
                       FontSize="18"
                       Margin="0,8"
                       TextAlignment="Center"/>

                            <TextBlock Text="{Binding SelectedFigureName, StringFormat=Выбранная фигура: {0}}"
                       FontSize="18"
                       Margin="0,8"
                       TextAlignment="Center"/>

                            <TextBlock Text="{Binding CurrentBlockCount, StringFormat=Количество блоков: {0}}"
                       FontSize="18"
                       Margin="0,8"
                       TextAlignment="Center"/>

                            <TextBlock Text="{Binding CurrentConnectionCount, StringFormat=Количество связей: {0}}"
                       FontSize="18"
                       Margin="0,8"
                       TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                </Border>

                <!-- Нижняя панель -->
                <Border Grid.Row="2"
        Grid.Column="2"
        CornerRadius="8"
        BorderBrush="Black"
        BorderThickness="2"
        Background="#ECECEC"
        Padding="10" Margin="0,30,0,-15">

                    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                        <Button Content="Создать"
                Width="120"
                Height="35"
                Margin="10,0"
                Command="{Binding CreateWorkspaceCommand}"/>

                        <Button Content="Открыть"
                Width="120"
                Height="35"
                Margin="10,0"/>

                        <Button Content="Сохранить"
                Width="120"
                Height="35"
                Margin="10,0"/>

                        <Button Content="Экспортировать"
                Width="120"
                Height="35"
                Margin="10,0"/>
                    </StackPanel>

                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>