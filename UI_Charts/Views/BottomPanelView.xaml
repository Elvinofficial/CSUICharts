<UserControl x:Class="UICharts.Desktop.Views.BottomPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        CornerRadius="8"
        BorderBrush="Black"
        BorderThickness="2"
        Background="#ECECEC"
        Padding="10">

        <StackPanel
            Orientation="Horizontal"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Height="55"
            Width="554">

            <Button
                Content="Создать"
                Width="60"
                Height="32"
                Margin="10,0"
                Command="{Binding CreateWorkspaceCommand}"/>

            <Button
                Content="Открыть"
                Width="80"
                Height="35"
                Margin="10,0"
                Command="{Binding DataContext.LoadProjectCommand,
              RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Button
                Content="Сохранить"
                Width="80"
                Height="35"
                Margin="10,0"
                Command="{Binding DataContext.SaveProjectCommand,
              RelativeSource={RelativeSource AncestorType=Window}}"/>

            <Button
                Content="Экспортировать"
                Width="100"
                Height="36"
                Margin="10,0"
                Command="{Binding DataContext.ExportPngCommand,
                    RelativeSource={RelativeSource AncestorType=Window}}"
                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Button
    Content="Справка"
    Width="130"
    Height="35"
    Margin="10,0"
    Command="{Binding DataContext.ShowHelpCommand,
              RelativeSource={RelativeSource AncestorType=Window}}"/>

        </StackPanel>
    </Border>
</UserControl>