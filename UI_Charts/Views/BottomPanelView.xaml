<UserControl x:Class="UICharts.Desktop.Views.BottomPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        CornerRadius="8"
        BorderBrush="Black"
        BorderThickness="2"
        Background="#ECECEC"
        Padding="10">

        <StackPanel
            Orientation="Horizontal"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Height="55"
            Width="554">

            <Button
                Content="Создать"
                Width="120"
                Height="32"
                Margin="10,0"
                Command="{Binding CreateWorkspaceCommand}"/>

            <Button
                Content="Открыть"
                Width="120"
                Height="35"
                Margin="10,0"/>

            <Button
                Content="Сохранить"
                Width="120"
                Height="35"
                Margin="10,0"/>

            <Button
                Content="Экспортировать"
                Width="120"
                Height="36"
                Margin="10,0"/>

        </StackPanel>
    </Border>
</UserControl>