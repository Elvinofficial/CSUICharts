<UserControl 
    x:Class="UICharts.Desktop.Views.ToolboxView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:enums="clr-namespace:UICharts.Core.Enums;assembly=UICharts.Core"
    mc:Ignorable="d" 
    d:DesignHeight="450"
    d:DesignWidth="220">

    <Border 
        CornerRadius="25"
        BorderBrush="Black"
        BorderThickness="2"
        Background="#ECECEC"
        Padding="12"
        Margin="-19,-15,5,-15">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Фигуры"
                       FontSize="20"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Figures}"
                     SelectedItem="{Binding SelectedFigure}"
                     Background="Transparent"
                     BorderThickness="0"
                     FontSize="15"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0,4"/>
                        <Setter Property="Padding" Value="6"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">

                            <Grid Width="48"
                                  Height="34"
                                  Margin="0,0,10,0">

                                <Rectangle Stroke="Black"
                                           Fill="White"
                                           StrokeThickness="2">
                                    <Rectangle.Style>
                                        <Style TargetType="Rectangle">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static enums:BlockType.Process}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static enums:BlockType.Procedure}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>

                                <Polygon Points="24,0 48,17 24,34 0,17"
                                         Stroke="Black"
                                         Fill="White"
                                         StrokeThickness="2">
                                    <Polygon.Style>
                                        <Style TargetType="Polygon">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static enums:BlockType.Decision}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Polygon.Style>
                                </Polygon>

                                <Ellipse Stroke="Black"
                                         Fill="White"
                                         StrokeThickness="2">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static enums:BlockType.Start}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static enums:BlockType.End}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static enums:BlockType.Reference}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <Polygon Points="10,0 48,0 38,34 0,34"
                                         Stroke="Black"
                                         Fill="White"
                                         StrokeThickness="2">
                                    <Polygon.Style>
                                        <Style TargetType="Polygon">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static enums:BlockType.InputOutput}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Polygon.Style>
                                </Polygon>

                                <Polygon Points="8,0 40,0 48,17 40,34 8,34 0,17"
                                         Stroke="Black"
                                         Fill="White"
                                         StrokeThickness="2">
                                    <Polygon.Style>
                                        <Style TargetType="Polygon">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static enums:BlockType.Loop}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Polygon.Style>
                                </Polygon>

                                <Grid>
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static enums:BlockType.Procedure}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>

                                    <Line X1="8" Y1="0" X2="8" Y2="34"
                                          Stroke="Black"
                                          StrokeThickness="2"/>

                                    <Line X1="40" Y1="0" X2="40" Y2="34"
                                          Stroke="Black"
                                          StrokeThickness="2"/>
                                </Grid>

                            </Grid>

                            <TextBlock Text="{Binding Name}"
                                       VerticalAlignment="Center"
                                       FontSize="15"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

           
        </Grid>
    </Border>
</UserControl>