<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:enums="clr-namespace:UICharts.Core.Enums;assembly=UICharts.Core"
    xmlns:behaviors="clr-namespace:UICharts.Desktop.Behaviors">
    
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Процесс -->
        <DataTemplate x:Key="ProcessTemplate">
            <Grid Width="{Binding Width}"
            Height="{Binding Height}"
            behaviors:BlockClickBehavior.InteractionCanvas="{Binding ElementName=EditorCanvas}"
            behaviors:BlockClickBehavior.MouseDownCommand="{Binding DataContext.BlockMouseDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"

            behaviors:BlockDragBehavior.InteractionCanvas="{Binding ElementName=EditorCanvas}"
            behaviors:BlockDragBehavior.MouseMoveCommand="{Binding DataContext.BlockMouseMoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
            behaviors:BlockDragBehavior.MouseUpCommand="{Binding DataContext.BlockMouseUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <Rectangle>
                    <Rectangle.Style>
                        <Style TargetType="Rectangle">
                            <Setter Property="Fill" Value="White"/>
                            <Setter Property="Stroke" Value="Black"/>
                            <Setter Property="StrokeThickness" Value="2"/>

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Fill" Value="#EAF3FF"/>
                                    <Setter Property="Stroke" 
                                            Value="DodgerBlue"/>
                                    <Setter Property="StrokeThickness" Value="3"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>

                <TextBlock Text="{Binding Text}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     TextAlignment="Center"
                     TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   behaviors:EditTextBoxBehavior.EndEditCommand=
                   "{Binding DataContext.EndEditBlockCommand,
                   RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            <ItemsControl ItemsSource="{Binding LocalConnectionPoints}"
              Visibility="{Binding ShowConnectionPoints, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X}" />
                        <Setter Property="Canvas.Top" Value="{Binding Y}" />
                    </Style>
                </ItemsControl.ItemContainerStyle>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Ellipse Width="10"
                     Height="10"
                     Fill="#8000AA00"
                     Stroke="Green"
                     StrokeThickness="1"
                     Margin="-5,-5,0,0"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Rectangle Width="10"
               Height="10"
               Fill="DodgerBlue"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Cursor="SizeNWSE"
               Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
               behaviors:BlockResizeBehavior.InteractionCanvas="{Binding ElementName=EditorCanvas}"
               behaviors:BlockResizeBehavior.MouseDownCommand="{Binding DataContext.BlockResizeMouseDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
               behaviors:BlockResizeBehavior.MouseMoveCommand="{Binding DataContext.BlockResizeMouseMoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
               behaviors:BlockResizeBehavior.MouseUpCommand="{Binding DataContext.BlockResizeMouseUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </Grid>
        </DataTemplate>

        <!-- Решение -->
        <DataTemplate x:Key="DecisionTemplate">
        <Grid Width="{Binding Width}"
          Height="{Binding Height}"
          behaviors:BlockClickBehavior.InteractionCanvas="{Binding ElementName=EditorCanvas}"
          behaviors:BlockClickBehavior.MouseDownCommand="{Binding DataContext.BlockMouseDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
          behaviors:BlockDragBehavior.InteractionCanvas="{Binding ElementName=EditorCanvas}"
          behaviors:BlockDragBehavior.MouseMoveCommand="{Binding DataContext.BlockMouseMoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
          behaviors:BlockDragBehavior.MouseUpCommand="{Binding DataContext.BlockMouseUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">

            <Viewbox Stretch="Fill">
                <Polygon Points="60,0 120,40 60,80 0,40">
                    <Polygon.Style>
                        <Style TargetType="Polygon">
                            <Setter Property="Fill" Value="White"/>
                            <Setter Property="Stroke" Value="Black"/>
                            <Setter Property="StrokeThickness" Value="2"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Fill" Value="#EAF3FF"/>
                                    <Setter Property="Stroke" Value="DodgerBlue"/>
                                    <Setter Property="StrokeThickness" Value="3"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Polygon.Style>
                </Polygon>
            </Viewbox>

            <TextBlock Text="{Binding Text}"
     HorizontalAlignment="Center"
     VerticalAlignment="Center"
     TextAlignment="Center"
     TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
   HorizontalAlignment="Stretch"
   VerticalAlignment="Center"
   TextAlignment="Center"
   TextWrapping="Wrap"
   behaviors:EditTextBoxBehavior.EndEditCommand=
   "{Binding DataContext.EndEditBlockCommand,
    RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            <ItemsControl ItemsSource="{Binding LocalConnectionPoints}"
              Visibility="{Binding ShowConnectionPoints, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X}" />
                        <Setter Property="Canvas.Top" Value="{Binding Y}" />
                    </Style>
                </ItemsControl.ItemContainerStyle>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Ellipse Width="10"
                     Height="10"
                     Fill="#8000AA00"
                     Stroke="Green"
                     StrokeThickness="1"
                     Margin="-5,-5,0,0"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Rectangle Width="10"
            Height="10"
            Fill="DodgerBlue"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,20,5"
            Cursor="SizeNWSE"
            Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
            behaviors:BlockResizeBehavior.InteractionCanvas="{Binding ElementName=EditorCanvas}"
            behaviors:BlockResizeBehavior.MouseDownCommand="{Binding DataContext.BlockResizeMouseDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
            behaviors:BlockResizeBehavior.MouseMoveCommand="{Binding DataContext.BlockResizeMouseMoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
            behaviors:BlockResizeBehavior.MouseUpCommand="{Binding DataContext.BlockResizeMouseUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>  
        </Grid>
        </DataTemplate>

