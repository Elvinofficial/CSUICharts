<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:enums="clr-namespace:UICharts.Core.Enums;assembly=UICharts.Core"
    xmlns:behaviors="clr-namespace:UICharts.Desktop.Behaviors">

        <!-- Процесс -->
        <DataTemplate x:Key="ProcessTemplate">
            <Grid Width="120"
            Height="60"
            behaviors:BlockClickBehavior.InteractionCanvas="{Binding RelativeSource={RelativeSource AncestorType=Canvas}}"
            behaviors:BlockClickBehavior.MouseDownCommand="{Binding DataContext.BlockMouseDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"

            behaviors:BlockDragBehavior.InteractionCanvas="{Binding ElementName=EditorCanvas}"
            behaviors:BlockDragBehavior.MouseMoveCommand="{Binding DataContext.BlockMouseMoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
            behaviors:BlockDragBehavior.MouseUpCommand="{Binding DataContext.BlockMouseUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <Rectangle>
                    <Rectangle.Style>
                        <Style TargetType="Rectangle">
                            <Setter Property="Fill" Value="White"/>
                            <Setter Property="Stroke" Value="Black"/>
                            <Setter Property="StrokeThickness" Value="2"/>

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Fill" Value="#EAF3FF"/>
                                    <Setter Property="Stroke" 
                                            Value="DodgerBlue"/>
                                    <Setter Property="StrokeThickness" Value="3"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>

                <TextBlock Text="{Binding Text}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     TextAlignment="Center"
                     TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   behaviors:EditTextBoxBehavior.EndEditCommand=
                   "{Binding DataContext.EndEditBlockCommand,
                   RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Grid>
        </DataTemplate>

        <!-- Решение -->
        <DataTemplate x:Key="DecisionTemplate">
            <Grid Width="120"
            Height="80"
            behaviors:BlockClickBehavior.InteractionCanvas="{Binding ElementName=EditorCanvas}"
behaviors:BlockClickBehavior.MouseDownCommand="{Binding DataContext.BlockMouseDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"

behaviors:BlockDragBehavior.InteractionCanvas="{Binding ElementName=EditorCanvas}"
behaviors:BlockDragBehavior.MouseMoveCommand="{Binding DataContext.BlockMouseMoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
behaviors:BlockDragBehavior.MouseUpCommand="{Binding DataContext.BlockMouseUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <Polygon Points="60,0 120,40 60,80 0,40">
                    <Polygon.Style>
                        <Style TargetType="Polygon">
                            <Setter Property="Fill" Value="White"/>
                            <Setter Property="Stroke" Value="Black"/>
                            <Setter Property="StrokeThickness" Value="2"/>

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Fill" Value="#EAF3FF"/>
                                    <Setter Property="Stroke" Value="DodgerBlue"/>
                                    <Setter Property="StrokeThickness" Value="3"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Polygon.Style>
                </Polygon>

                <TextBlock Text="{Binding Text}"
     HorizontalAlignment="Center"
     VerticalAlignment="Center"
     TextAlignment="Center"
     TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
   HorizontalAlignment="Stretch"
   VerticalAlignment="Center"
   TextAlignment="Center"
   TextWrapping="Wrap"
   behaviors:EditTextBoxBehavior.EndEditCommand=
   "{Binding DataContext.EndEditBlockCommand,
    RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>


            </Grid>
        </DataTemplate>

        <!-- Начало / конец -->
        <DataTemplate x:Key="StartEndTemplate">
            <Grid Width="120"
            Height="60"
            behaviors:BlockClickBehavior.InteractionCanvas="{Binding ElementName=EditorCanvas}"
behaviors:BlockClickBehavior.MouseDownCommand="{Binding DataContext.BlockMouseDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"

behaviors:BlockDragBehavior.InteractionCanvas="{Binding ElementName=EditorCanvas}"
behaviors:BlockDragBehavior.MouseMoveCommand="{Binding DataContext.BlockMouseMoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
behaviors:BlockDragBehavior.MouseUpCommand="{Binding DataContext.BlockMouseUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <Ellipse>
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="White"/>
                            <Setter Property="Stroke" Value="Black"/>
                            <Setter Property="StrokeThickness" Value="2"/>

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Fill" Value="#EAF3FF"/>
                                    <Setter Property="Stroke" Value="DodgerBlue"/>
                                    <Setter Property="StrokeThickness" Value="3"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>

                <TextBlock Text="{Binding Text}"
     HorizontalAlignment="Center"
     VerticalAlignment="Center"
     TextAlignment="Center"
     TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
   HorizontalAlignment="Stretch"
   VerticalAlignment="Center"
   TextAlignment="Center"
   TextWrapping="Wrap"
   behaviors:EditTextBoxBehavior.EndEditCommand=
   "{Binding DataContext.EndEditBlockCommand,
    RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

            </Grid>
        </DataTemplate>

        <!-- Ввод / вывод -->
        <DataTemplate x:Key="InputOutputTemplate">
        <Grid Width="140"
            Height="60"
            behaviors:BlockClickBehavior.InteractionCanvas="{Binding ElementName=EditorCanvas}"
behaviors:BlockClickBehavior.MouseDownCommand="{Binding DataContext.BlockMouseDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"

behaviors:BlockDragBehavior.InteractionCanvas="{Binding ElementName=EditorCanvas}"
behaviors:BlockDragBehavior.MouseMoveCommand="{Binding DataContext.BlockMouseMoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
behaviors:BlockDragBehavior.MouseUpCommand="{Binding DataContext.BlockMouseUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <Polygon Points="20,0 140,0 120,60 0,60">
                <Polygon.Style>
                    <Style TargetType="Polygon">
                        <Setter Property="Fill" Value="White"/>
                        <Setter Property="Stroke" Value="Black"/>
                        <Setter Property="StrokeThickness" Value="2"/>

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Fill" Value="#EAF3FF"/>
                                <Setter Property="Stroke" Value="DodgerBlue"/>
                                <Setter Property="StrokeThickness" Value="3"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Polygon.Style>
            </Polygon>

            <TextBlock Text="{Binding Text}"
     HorizontalAlignment="Center"
     VerticalAlignment="Center"
     TextAlignment="Center"
     TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
   HorizontalAlignment="Stretch"
   VerticalAlignment="Center"
   TextAlignment="Center"
   TextWrapping="Wrap"
   behaviors:EditTextBoxBehavior.EndEditCommand=
   "{Binding DataContext.EndEditBlockCommand,
    RelativeSource={RelativeSource AncestorType=UserControl}}">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </Grid>
    </DataTemplate>
</ResourceDictionary>
